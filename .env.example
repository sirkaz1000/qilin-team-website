# Database (PostgreSQL required for Vercel deployment)
DATABASE_URL="postgresql://username:password@host:5432/qilin-team"
# Alternative: Local PostgreSQL
# DATABASE_URL="postgresql://localhost:5432/qilin-team"

# JWT Secret
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL_PROD="https://your-domain.com"

# File Upload (Cloudinary or similar)
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"
CLOUDINARY_UPLOAD_PRESET="your-upload-preset"

# Email Service (Optional - for notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="noreply@your-domain.com"

# Analytics (Optional)
NEXT_PUBLIC_GA_ID="your-google-analytics-id"
