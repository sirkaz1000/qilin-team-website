generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(cuid())
  username       String          @unique
  email          String          @unique
  passwordHash   String
  displayName    String
  avatarUrl      String?
  role           UserRole        @default(USER)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  achievements   Achievement[]
  comments       Comment[]
  commits        Commit[]
  notifications  Notification[]
  posts          Post[]
  repositories   Repository[]
  storeOrders    StoreOrder[]
  storeReviews   StoreReview[]
  supportTickets SupportTicket[]
}

model Post {
  id        String    @id @default(cuid())
  title     String
  content   String
  authorId  String
  isPinned  Boolean   @default(false)
  createdAt DateTime  @default(now())
  comments  Comment[]
  author    User      @relation(fields: [authorId], references: [id])
}

model Achievement {
  id          String    @id @default(cuid())
  title       String
  description String
  iconUrl     String?
  isFeatured  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  comments    Comment[]
}

model Comment {
  id         String      @id @default(cuid())
  content    String
  userId     String
  targetType String
  targetId   String
  createdAt  DateTime    @default(now())
  post       Achievement @relation(fields: [targetId], references: [id], map: "Comment_postId_fkey")
  post       Post        @relation(fields: [targetId], references: [id], map: "Comment_postId_fkey")
  user       User        @relation(fields: [userId], references: [id])
}

model Repository {
  id          String           @id @default(cuid())
  name        String
  description String?
  ownerId     String
  isPublic    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  commits     Commit[]
  owner       User             @relation(fields: [ownerId], references: [id])
  files       RepositoryFile[]
}

model RepositoryFile {
  id           String     @id @default(cuid())
  repositoryId String
  path         String
  content      String
  commitHash   String
  createdAt    DateTime   @default(now())
  repository   Repository @relation(fields: [repositoryId], references: [id])

  @@unique([repositoryId, path])
}

model Commit {
  id           String     @id @default(cuid())
  repositoryId String
  message      String
  authorId     String
  hash         String     @unique
  createdAt    DateTime   @default(now())
  author       User       @relation(fields: [authorId], references: [id])
  repository   Repository @relation(fields: [repositoryId], references: [id])
}

model StoreItem {
  id          String        @id @default(cuid())
  title       String
  description String
  type        ItemType
  price       Float
  imageUrl    String?
  createdAt   DateTime      @default(now())
  orders      StoreOrder[]
  reviews     StoreReview[]
}

model StoreOrder {
  id        String      @id @default(cuid())
  itemId    String
  userId    String
  status    OrderStatus @default(PENDING)
  createdAt DateTime    @default(now())
  item      StoreItem   @relation(fields: [itemId], references: [id])
  user      User        @relation(fields: [userId], references: [id])
}

model StoreReview {
  id        String    @id @default(cuid())
  itemId    String
  userId    String
  rating    Int
  comment   String?
  createdAt DateTime  @default(now())
  item      StoreItem @relation(fields: [itemId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([itemId, userId])
}

model SupportTicket {
  id        String       @id @default(cuid())
  userId    String
  subject   String
  message   String
  status    TicketStatus @default(OPEN)
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id])
}

model FAQ {
  id         Int      @id @default(autoincrement())
  questionAr String
  questionEn String
  answerAr   String
  answerEn   String
  order      Int      @default(0)
  createdAt  DateTime @default(now())
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  content   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id])
}

model SiteSettings {
  id              Int      @id @default(1)
  siteName        String   @default("The Qilin Team")
  siteDescription String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum UserRole {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum NotificationType {
  COMMENT
  NEW_USER
  SUPPORT_TICKET
  STORE_ORDER
  SYSTEM
}

enum ItemType {
  SERVICE
  PRODUCT
}
